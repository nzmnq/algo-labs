import unittest
from graph import count_valid_pairs 

class TestIslanderMatch(unittest.TestCase):

    def test_example_1_simple_tribes(self):
        n = 3
        pairs = [(1, 2), (2, 4), (3, 5)]
        
        result = count_valid_pairs(n, pairs)
        self.assertEqual(result, 4, "Error: Expected 4.")

    def test_example_2_complex_tribes(self):
        n = 5
        pairs = [
            (1, 2), 
            (2, 4), 
            (1, 3), 
            (3, 5), 
            (8, 10)
        ]
        
        result = count_valid_pairs(n, pairs)
        self.assertEqual(result, 6, "Error: Expected 6.")

if __name__ == '__main__':
    unittest.main()